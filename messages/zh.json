  "gettingStarted": {
    "title": "快速开始",
    "subtitle": "开始迁移前需要了解的事项",
    "sections": {
      "overview": {
        "title": "Trading API 与 GraphQL API 的区别",
        "items": [
          "Trading API 使用 SOAP/XML 格式。新 API 使用 GraphQL（JSON）或 REST（JSON）。",
          "认证方式从 AppID/CertID 变更为 OAuth 2.0。",
          "站点 ID（`siteid: 0`）变更为 `X-EBAY-C-MARKETPLACE-ID` 请求头。",
          "分页方式从偏移量分页变更为游标分页。"
        ]
      },
      "endpoint": {
        "title": "GraphQL 端点",
        "url": "https://graphqlapi.ebay.com/graphql",
        "note": "每个 API 都有独立的端点，请查阅各 API 文档。"
      },
      "auth": {
        "title": "认证变更",
        "description": "从 Trading API 的 AppID/CertID 方式迁移至 OAuth 2.0。",
        "steps": [
          "在 eBay 开发者平台获取 OAuth 凭证（Client ID / Client Secret）",
          "根据用途选择合适的 OAuth Scope",
          "通过 Client Credentials Grant（应用级别）或 Authorization Code Grant（用户级别）获取 Token",
          "在所有 API 请求头中携带 `Authorization: Bearer {token}`"
        ]
      },
      "scopes": {
        "title": "主要 OAuth Scope 列表",
        "items": [
