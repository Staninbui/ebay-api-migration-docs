          { "scope": "https://api.ebay.com/oauth/api_scope/sell.listing", "use": "创建/更新/下架/读取商品（读写合并）", "grant": "Authorization Code" },
          
          { "scope": "https://api.ebay.com/oauth/api_scope/sell.fulfillment", "use": "订单管理", "grant": "Authorization Code" },
